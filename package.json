{
  "name": "fittrack",
  "version": "1.0.0",
  "description": "Personal body transformation tracker",
  "type": "module",
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "node --watch server/index.js",
    "dev:all": "concurrently --names \"CLIENT,SERVER\" --prefix-colors \"cyan,yellow\" \"npm run dev:client\" \"npm run dev:server\"",
    "install:all": "npm install && npm install --prefix client",
    "test": "npm test --prefix client",
    "start": "npm run dev:all"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
